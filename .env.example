# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# LLM Backend
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# TTS Backend (optional - only needed if using ElevenLabs)
ELEVENLABS_API_KEY=...

# HuggingFace (for gated model access)
HUGGINGFACE_TOKEN=hf_...

# Experiment tracking
WANDB_API_KEY=...
WANDB_PROJECT=aiva-companion

# Avatar backend URL (if running a separate avatar service)
AVATAR_SERVICE_URL=http://localhost:8765

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
